<div id="leaderboard">
<ol>
<% @attempts.each do |attempt| %>
<div class="leaderboard-row <%= 'alert-secondary' if attempt.team == current_user.team %> <%= 'alert-success' if @attempts.first %>">
  <li>
    <div class="row">
      <div class="col-sm-2">
        <h5><%= attempt.team.name %></h5>
      </div>
      <div class="col-sm-10 text-right">
        <% if @quiz.attempts.where(team_id: attempt.team.id).present? %>
          <h5><%= @quiz.attempts.where(team_id: attempt.team.id).first.points %></h5>
        <% else %>
          Not started
        <% end %>
      </div>
    </div>
  </li>
    <div class="progress">
      <div class="progress-bar <%= animation_helper(@quiz, attempt.team) %>" role="progressbar" aria-valuenow="<%= progress_helper(@quiz, attempt.team) %>" aria-valuemin="0" aria-valuemax="100" style="width: <%= progress_helper(@quiz, attempt.team) %>%"></div>
    </div>
  </div>
  <hr />
<% end %>
</ol>
</div>
