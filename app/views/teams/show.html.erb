<p id="notice"><%= notice %></p>

<h1><%= @team.name %></h1>
<h3><%= @team.course.name %></h3>
<hr />
<% if @team.users.any? %>
  <ul class="list-group">
    <li class="list-group-item">Team members</li>
    <% @team.users.each do |user| %>
      <li class="list-group-item"><%= link_to user.username, user_path(user.username) %></li>
    <% end %>
  </ul>
<% end %>

<% if @attempts.any? %>
  <% @attempts.each do |attempt| %>
    <%= attempt.quiz.name %> | <%= pluralize Attempt.where(quiz_id: attempt.quiz.id, user_id: current_user.id, team_attempt: false).first.points, "My point" %> | <%= pluralize attempt.points, "Team point" %>
    <hr />
  <% end %>
<% end %>

<hr />
<% if current_user.team == @team %>
<% else %>
  <%= link_to "Join Team", memberships_path(team_id: @team.id), method: :post %>
<% end %></br>
<% if current_user.admin? %>
  <%= link_to 'Edit', edit_team_path(@team) %> |
  <%= link_to 'Back', teams_path %>
<% end %>
