
<h3>Available courses</h3>
  <% @courses.each do | course | %>
    <%= link_to course.name, quizzes_path %> <%= link_to "Join this Course", enrollments_path(course_id: course.id, user_id: current_user.id), method: :post, class: "btn btn-sm btn-primary" unless current_user.enrolled_courses.exists?(course.id) %>
  <% end %>
